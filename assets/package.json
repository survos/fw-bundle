{
  "name": "@survos/fw",
  "description": "integrate Framework7 and related mobile libraries with Symfony",
  "license": "MIT",
  "version": "1.0.5",
  "symfony": {
    "controllers": {
      "mobile": {
        "main": "src/controllers/mobile_controller.js",
        "webpackMode": "eager",
        "fetch": "lazy",
        "enabled": true,
        "autoimport": {
          "framework7/css/bundle": true
        }
      }
    },
    "importmap": {
      "@survos-mobile/mobile": "path:%PACKAGE%/src/controllers/mobile_controller.js",
      "debug": "^4.4.3",
      "framework7": "^9.0.4",
      "framework7/bundle": "^9.0.4",
      "framework7/css/bundle": "^9.0.4"
    }
  },
  "peerDependencies": {
    "@hotwired/stimulus": "^3.2.0"
  },
  "devDependencies": {
    "@hotwired/stimulus": "^3.2.2"
  },
  "dependencies": {
    "debug": "^4.4.3",
    "framework7": "^9.0.4"
  }
}
