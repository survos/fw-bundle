{
    "name": "survos/fw-bundle",
    "description": "Bundle with utilities for creating a Symfony-based mobile app with framework7",
    "keywords": [
        "symfony-ux"
    ],
    "license": "MIT",
    "type": "symfony-bundle",
    "minimum-stability": "beta",
    "prefer-stable": true,
    "require": {
        "php": "^8.4",
        "symfony/config": "^8.1",
        "symfony/dependency-injection": "^8.1",
        "symfony/http-kernel": "^8.1",
        "twig/twig": "^3.4",
        "survos/kit-bundle": "^2.0",
        "knplabs/knp-menu-bundle": "^3.2",
        "symfony/event-dispatcher": "^8.1",
        "symfony/ux-twig-component": "^3.0",
        "symfony/options-resolver": "^8.1",
        "symfony/console": "^8.1"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "symfony/browser-kit": "^8.1",
        "symfony/framework-bundle": "^8.1",
        "symfony/phpunit-bridge": "^8.1",
        "symfony/twig-bundle": "^8.1",
        "symfony/var-dumper": "^8.1",
        "symfony/security-bundle": "^8.1",
        "survos/auth-bundle": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Survos\\FwBundle\\": "src/"
        }
    },
    "suggest": {
        "intl-extra": "For better performance, install the intl-extra package to use the IntlDateFormatter class."
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "^8.1"
        }
    }
}
